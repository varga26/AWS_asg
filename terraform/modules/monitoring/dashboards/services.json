{
  "title": "Service Statuses",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Ollama Service Status (Healthy Nodes)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "LoadBalancer": "${ollama_lb_arn_suffix}",
            "TargetGroup": "${ollama_target_group_arn_suffix}"
          },
          "metricName": "HealthyHostCount",
          "namespace": "AWS/NetworkELB",
          "period": "60",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OpenWebUI Status (Healthy Nodes)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}",
            "TargetGroup": "${openwebui_target_group_arn_suffix}"
          },
          "metricName": "HealthyHostCount",
          "namespace": "AWS/ApplicationELB",
          "period": "60",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database Active Connections",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "DBInstanceIdentifier": "${rds_identifier}"
          },
          "metricName": "DatabaseConnections",
          "namespace": "AWS/RDS",
          "period": "60",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    }
  ]
}