{
  "title": "AWS RDS (Detailed)",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "type": "stat",
      "title": "CPU Utilization (Max)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "CPUUtilization",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Database Connections (Avg)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "DatabaseConnections",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "type": "stat",
      "title": "Freeable Memory (Min)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "FreeableMemory",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Minimum",
          "period": "300",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 268435456 },
              { "color": "green", "value": 1073741824 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Free Storage Space (Min)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "FreeStorageSpace",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Minimum",
          "period": "300",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5368709120 },
              { "color": "green", "value": 10737418240 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Utilization over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "CPUUtilization",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "CPU Utilization (%)",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "I/O Operations per Second (IOPS)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "ReadIOPS",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Read IOPS",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "WriteIOPS",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Write IOPS",
          "refId": "B",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Disk Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "ReadLatency",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Read Latency",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "WriteLatency",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Write Latency",
          "refId": "B",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Throughput & Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "ReadThroughput",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Read Throughput (B/s)",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "WriteThroughput",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Write Throughput (B/s)",
          "refId": "B",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${cloudwatch_uid}" },
          "namespace": "AWS/RDS",
          "metricName": "DiskQueueDepth",
          "dimensions": { "DBInstanceIdentifier": "${rds_identifier}" },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "alias": "Disk Queue Depth",
          "refId": "C",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryC"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Disk Queue Depth" }, "properties": [ { "id": "custom.axisPlacement", "value": "right" } ] }
        ]
      }
    }
  ]
}
