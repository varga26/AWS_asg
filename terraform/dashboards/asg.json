{
  "title": "AWS ASG (Detailed)",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "type": "stat",
      "title": "In Service Instances",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupInServiceInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Pending Instances",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupPendingInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Terminating Instances",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupTerminatingInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Desired Capacity",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupDesiredCapacity",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "ASG Instance Lifecycle",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupInServiceInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "In Service",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupPendingInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "Pending",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/AutoScaling",
          "metricName": "GroupTerminatingInstances",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "Terminating",
          "refId": "C",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryC"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 1,
            "fillOpacity": 40,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "In Service"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pending"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Terminating"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Aggregated CPU Utilization",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "60",
          "alias": "Average CPU",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "Max CPU",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Aggregated Network Traffic",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/EC2",
          "metricName": "NetworkIn",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "60",
          "alias": "Network In (Bytes)",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/EC2",
          "metricName": "NetworkOut",
          "dimensions": {
            "AutoScalingGroupName": "${asg_name}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "60",
          "alias": "Network Out (Bytes)",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}