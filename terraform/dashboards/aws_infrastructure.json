{
  "title": "AWS Infrastructure",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "RDS CPU Utilization",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "DBInstanceIdentifier": "${rds_identifier}"
          },
          "metricName": "CPUUtilization",
          "namespace": "AWS/RDS",
          "period": "300",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RDS Freeable Memory (Bytes)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "DBInstanceIdentifier": "${rds_identifier}"
          },
          "metricName": "FreeableMemory",
          "namespace": "AWS/RDS",
          "period": "300",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RDS Free Storage Space (Bytes)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "DBInstanceIdentifier": "${rds_identifier}"
          },
          "metricName": "FreeStorageSpace",
          "namespace": "AWS/RDS",
          "period": "300",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "stat",
      "title": "ELB Healthy Host Count",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}",
            "TargetGroup": "${target_group_arn_suffix}"
          },
          "metricName": "HealthyHostCount",
          "namespace": "AWS/ApplicationELB",
          "period": "300",
          "region": "default",
          "statistic": "Average",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ELB 4XX Errors",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "metricName": "HTTPCode_Target_4XX_Count",
          "namespace": "AWS/ApplicationELB",
          "period": "300",
          "region": "default",
          "statistic": "Sum",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ELB 5XX Errors",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "metricName": "HTTPCode_Target_5XX_Count",
          "namespace": "AWS/ApplicationELB",
          "period": "300",
          "region": "default",
          "statistic": "Sum",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ]
    }
  ]
}