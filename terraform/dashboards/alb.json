{
  "title": "AWS ALB (Detailed)",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests (5m)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "RequestCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "ELB 5XX Errors",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_ELB_5XX_Count",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Avg Response Time",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "TargetResponseTime",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "300",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "stat",
      "title": "Unhealthy Hosts",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "UnHealthyHostCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}",
            "TargetGroup": "${target_group_arn_suffix}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "300",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rates (2XX, 3XX, 4XX, 5XX)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_2XX_Count",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "60",
          "alias": "2XX",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_3XX_Count",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "60",
          "alias": "3XX",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_4XX_Count",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "60",
          "alias": "4XX",
          "refId": "C",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryC"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_5XX_Count",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "60",
          "alias": "5XX",
          "refId": "D",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryD"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5XX"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4XX"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "2XX"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Response Time / Latency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "TargetResponseTime",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "60",
          "alias": "Average Response",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "TargetResponseTime",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "p99",
          "period": "60",
          "alias": "p99 Response",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Healthy vs Unhealthy Hosts",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "HealthyHostCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}",
            "TargetGroup": "${target_group_arn_suffix}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "Healthy Hosts",
          "refId": "A",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "UnHealthyHostCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}",
            "TargetGroup": "${target_group_arn_suffix}"
          },
          "region": "default",
          "statistic": "Maximum",
          "period": "60",
          "alias": "Unhealthy Hosts",
          "refId": "B",
          "matchExact": false,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Unhealthy Hosts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Healthy Hosts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Connections & Processed Bytes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "ActiveConnectionCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Average",
          "period": "60",
          "alias": "Active Connections",
          "refId": "A",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryA"
        },
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "${cloudwatch_uid}"
          },
          "namespace": "AWS/ApplicationELB",
          "metricName": "NewConnectionCount",
          "dimensions": {
            "LoadBalancer": "${alb_arn_suffix}"
          },
          "region": "default",
          "statistic": "Sum",
          "period": "60",
          "alias": "New Connections",
          "refId": "B",
          "matchExact": true,
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "id": "queryB"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          }
        }
      }
    }
  ]
}